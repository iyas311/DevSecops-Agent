# =============================================================================
# Cloud Identity Security Assistant (CISA) — Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment.

# --- AWS Configuration ---
AWS_REGION=us-east-1
# AWS_PROFILE=default                    # Optional: AWS CLI profile name
# AWS_ACCESS_KEY_ID=                     # Optional: Use if not using profiles
# AWS_SECRET_ACCESS_KEY=                 # Optional: Use if not using profiles

# --- Amazon Bedrock ---
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0
# BEDROCK_KB_ID=                         # Optional: Bedrock Knowledge Base ID

# --- Application ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=8501
BACKEND_URL=http://localhost:8000
LOG_LEVEL=INFO

# --- Agent Configuration ---
MAX_TOOL_ITERATIONS=10                   # Max tool-calling loops per request
MAX_CONVERSATION_TURNS=20               # Max conversation turns in memory
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.3                  # Lower = more focused for security analysis
